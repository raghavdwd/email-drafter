# database connection string (replace with your mysql credentials)
DATABASE_URL="mysql://root:password@localhost:3306/email_drafter"

# google oauth client id (get from google cloud console)
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"

# admin credentials for hardcoded login
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# jwt secret for token signing
JWT_SECRET="your-super-secret-jwt-key-change-this"

# server port
PORT=3000

# frontend and backend URLs for OAuth redirects
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:3000"

